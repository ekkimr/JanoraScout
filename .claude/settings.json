{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/ekkimr/Personal Project/JanoraScoutApp/.claude/hooks/block-dangerous-commands.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/ekkimr/Personal Project/JanoraScoutApp/.claude/hooks/run-linter.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/ekkimr/Personal Project/JanoraScoutApp/.claude/hooks/notify-done.sh'"
          },
          {
            "type": "command",
            "command": "bash '/Users/ekkimr/Personal Project/JanoraScoutApp/.claude/hooks/check-docs-needed.sh'"
          }
        ]
      }
    ]
  }
}
